# Third-party Anthropic-compatible endpoint config.
# Copy this file to .env (gitignored) and fill in real values.
# The .env file is loaded ONLY when scripts/step0_endpoint_check.py is run.
# It does NOT touch ~/.claude/ user config.

ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
ANTHROPIC_DEFAULT_HAIKU_MODEL=
ANTHROPIC_DEFAULT_SONNET_MODEL=
ANTHROPIC_DEFAULT_OPUS_MODEL=
API_TIMEOUT_MS=3000000
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
